# Monarch Money session token
# Obtain by running: node -e "const {MonarchMoney} = require('monarch-money'); const m = new MonarchMoney(); m.login('your@email.com','yourpassword').then(() => console.log(m.getToken()))"
MONARCH_TOKEN=your_token_here

# Optional: override the default SSE server port (default: 8775)
PORT=8775
